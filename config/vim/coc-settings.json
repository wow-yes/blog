{
    "semanticTokens.enable": true,
    "semanticTokens.highlightPriority": 1024,
    "clangd.enabled": true,
    "clangd.arguments": [
        "--clang-tidy",
        "--header-insertion=never"
    ],
    "diagnostic.enable": true,
    "inlayHint.subSeparator": "︴",
    "inlayHints.enableParameter": true,
    "clangd.inlayHints.sep": "⇝"
}